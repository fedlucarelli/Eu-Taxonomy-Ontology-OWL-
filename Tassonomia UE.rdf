    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#belongsToSector -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#belongsToSector">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicSector"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#compliesWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#compliesWith">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#MinimumSafeguard"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#TechnicalScreeningCriteria"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#hasActivityType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#hasActivityType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#ActivityType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#isClassifiedAs -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#isClassifiedAs">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#TaxonomyAlignment"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#makesSubstantialContributionTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#makesSubstantialContributionTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EnvironmentalObjective"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#respectsDNSHWithRespectTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#respectsDNSHWithRespectTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EconomicActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/federicolucarelli/ontologies/2026/0/eu-taxonomy-formalization#EnvironmentalObjective"/>
    </owl:ObjectProperty>
    


